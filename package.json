{
  "name": "caos-studio",
  "productname": "Caos Studio",
  "version": "1.3.0",
  "main": "src/js/app.js",
  "scripts": {
    "start": "electron .",
    "dev": "cross-env-shell NODE_ENV=dev electron .",
    "build": "electron-builder build --win --publish never"
  },
  "build": {
    "appId": "com.chaosstudio.launcher",
    "productName": "Chaos Studio",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icono/ft2.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Chaos Studio"
    },
    "files": [
      "**/*",
      "!dist/*",
      "!web/*"
    ],
    "protocols": {
      "name": "Chaos Studio Protocol",
      "schemes": [
        "caos-launcher",
        "chaos-launcher"
      ]
    }
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "description": "",
  "devDependencies": {
    "electron": "^40.4.1",
    "electron-builder": "^26.7.0",
    "nodemon": "^3.1.11"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "electron-store": "^11.0.2",
    "minecraft-java-core": "^4.2.6",
    "minecraft-launcher-core": "^3.18.2",
    "msmc": "^5.0.5",
    "node-fetch": "^2.7.0"
  }
}
